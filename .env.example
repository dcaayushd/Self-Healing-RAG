RAG_CHROMA_PATH=data/chroma
RAG_CHECKPOINT_DB=data/checkpoints.sqlite
RAG_DEFAULT_COLLECTION=default
RAG_CHAT_MODEL=llama3:latest
RAG_EMBEDDING_MODEL=nomic-embed-text
RAG_OLLAMA_BASE_URL=http://localhost:11434
RAG_TOP_K=6
RAG_FETCH_K=20
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
RAG_MAX_ATTEMPTS=3
RAG_MIN_RETRIEVAL_CONFIDENCE=0.08
RAG_MAX_LEXICAL_SCAN=5000
RAG_RETRIEVAL_CACHE_SIZE=128
RAG_STATS_CACHE_SIZE=32
RAG_ANSWER_CACHE_SIZE=64
RAG_LLM_NUM_CTX=8192
RAG_ANSWER_NUM_PREDICT=512
RAG_CRITIC_NUM_PREDICT=256
RAG_REWRITE_NUM_PREDICT=96
RAG_CRITIC_MODE=local
RAG_USE_LLM_REWRITE=false
RAG_OLLAMA_KEEP_ALIVE=10m
RAG_ALLOW_PRIVATE_URLS=false
